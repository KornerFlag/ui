---
import BaseLayout from "../layouts/BaseLayout.astro";

const optionA = `${import.meta.env.BASE_URL}landing-option-a/`;
const optionB = `${import.meta.env.BASE_URL}landing-option-b/`;
const productPage = `${import.meta.env.BASE_URL}product/`;
---

<BaseLayout
  title="Korner Flags | Landing directions"
  description="Two modern landing-page directions for Korner Flags."
  activeNav="home"
>
  <div class="page options-page">
    <section class="selector-hero">
      <div class="selector-copy">
        <span class="eyebrow">New landing system</span>
        <h1 class="display">Two sleek front doors for the same product.</h1>
        <p>
          The product experience now lives separately. Choose between two marketing directions, then
          jump into the actual Korner Flags product page.
        </p>

        <div class="button-row">
          <a class="button-primary" href={optionA}>Open option A</a>
          <a class="button-secondary" href={optionB}>Open option B</a>
          <a class="button-secondary" href={productPage}>Go to product page</a>
        </div>
      </div>

      <div class="selector-panels">
        <article class="option-panel option-panel-a">
          <p>Option A</p>
          <h2>Dark, cinematic, and high-contrast.</h2>
          <span>Best for investor demos and premium positioning.</span>
        </article>
        <article class="option-panel option-panel-b">
          <p>Option B</p>
          <h2>Bright, editorial, and cleanly operational.</h2>
          <span>Best for clubs, coaches, and recruiting-heavy conversations.</span>
        </article>
      </div>
    </section>

    <section class="surface-card options-grid-wrap">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Compare directions</span>
          <h2>Both routes lead into the same product page</h2>
        </div>
        <p>
          Each option is a full landing-page concept rather than a moodboard. Both pages connect
          directly into the product page, dashboard, and match review experience.
        </p>
      </div>

      <div class="options-grid">
        <a class="marketing-card marketing-card-a" href={optionA}>
          <div>
            <p>Landing option A</p>
            <h3>Match Intelligence</h3>
            <span>Dark premium narrative with a stronger visual stage.</span>
          </div>
          <strong>Open option A</strong>
        </a>

        <a class="marketing-card marketing-card-b" href={optionB}>
          <div>
            <p>Landing option B</p>
            <h3>Club Operating System</h3>
            <span>Light modern narrative with crisp product framing.</span>
          </div>
          <strong>Open option B</strong>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .options-page {
    display: grid;
    gap: 30px;
  }

  .selector-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.85fr);
    gap: 22px;
    padding: 34px;
    border-radius: 34px;
    background:
      radial-gradient(circle at top right, rgba(107, 160, 216, 0.32), transparent 24%),
      linear-gradient(135deg, #08111c, #10253d 58%, #17385b);
    color: white;
    box-shadow: 0 30px 60px rgba(11, 22, 38, 0.16);
  }

  .selector-copy h1 {
    margin: 18px 0 0;
    max-width: 11ch;
    font-size: clamp(3.1rem, 6vw, 5.6rem);
    line-height: 0.94;
  }

  .selector-copy p {
    max-width: 680px;
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 1.05rem;
    line-height: 1.78;
  }

  .selector-copy .button-row {
    margin-top: 28px;
  }

  .selector-panels {
    display: grid;
    gap: 16px;
  }

  .option-panel {
    padding: 24px;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    min-height: 220px;
  }

  .option-panel-a {
    background:
      radial-gradient(circle at top right, rgba(89, 166, 241, 0.28), transparent 32%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
  }

  .option-panel-b {
    background:
      radial-gradient(circle at bottom left, rgba(232, 199, 107, 0.18), transparent 30%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
  }

  .option-panel p {
    margin: 0 0 14px;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .option-panel h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 2.05rem;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .option-panel span {
    display: block;
    margin-top: 18px;
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.65;
  }

  .options-grid-wrap {
    padding: 30px;
  }

  .options-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .marketing-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 18px;
    min-height: 280px;
    padding: 24px;
    border-radius: 28px;
    overflow: hidden;
    position: relative;
  }

  .marketing-card:before {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.9;
    pointer-events: none;
  }

  .marketing-card > * {
    position: relative;
    z-index: 1;
  }

  .marketing-card-a {
    color: white;
    background: linear-gradient(135deg, #0b1727, #132944 62%, #204d7a);
  }

  .marketing-card-a:before {
    background:
      radial-gradient(circle at 80% 20%, rgba(107, 160, 216, 0.34), transparent 20%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), transparent 45%);
  }

  .marketing-card-b {
    color: var(--ink-900);
    background: linear-gradient(135deg, #ffffff, #edf3f8 62%, #dfeaf4);
    border: var(--border-subtle);
  }

  .marketing-card-b:before {
    background:
      radial-gradient(circle at 18% 22%, rgba(31, 78, 130, 0.08), transparent 18%),
      radial-gradient(circle at 85% 78%, rgba(232, 199, 107, 0.18), transparent 20%);
  }

  .marketing-card p {
    margin: 0 0 12px;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.76;
  }

  .marketing-card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 2.2rem;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .marketing-card span {
    display: block;
    margin-top: 14px;
    line-height: 1.7;
    max-width: 28ch;
    opacity: 0.8;
  }

  .marketing-card strong {
    font-size: 1rem;
  }

  @media (max-width: 980px) {
    .selector-hero,
    .options-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .selector-hero,
    .options-grid-wrap {
      padding: 22px;
    }

    .selector-copy h1 {
      font-size: clamp(2.7rem, 12vw, 4.4rem);
    }
  }
</style>
