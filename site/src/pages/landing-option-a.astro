---
import BaseLayout from "../layouts/BaseLayout.astro";

const productPage = `${import.meta.env.BASE_URL}product/`;
const matchesPage = `${import.meta.env.BASE_URL}matches/`;
const otherOption = `${import.meta.env.BASE_URL}landing-option-b/`;
---

<BaseLayout
  title="Korner Flags | Landing option A"
  description="Modern landing-page option A for Korner Flags."
  activeNav="home"
>
  <div class="page landing-page-a">
    <section class="hero-a">
      <div class="hero-copy">
        <span class="eyebrow">Landing option A</span>
        <h1 class="display">The match room becomes the new standard of review.</h1>
        <p>
          A dark, premium landing direction that treats Korner Flags like a modern intelligence
          product: sleek hero stage, sharp data framing, and direct routes into the product page.
        </p>

        <div class="button-row">
          <a class="button-primary" href={productPage}>Enter product page</a>
          <a class="button-secondary" href={otherOption}>See option B</a>
        </div>
      </div>

      <div class="stage-a">
        <article class="signal-card main">
          <p>Why it works</p>
          <h2>Video leads. Analytics support. Coaches stay oriented.</h2>
          <span>
            Designed for a room where people need to trust what they’re seeing immediately.
          </span>
        </article>

        <div class="signal-grid">
          <article class="signal-card">
            <p>Review flow</p>
            <strong>Landing to product in one click</strong>
          </article>
          <article class="signal-card">
            <p>Positioning</p>
            <strong>Premium, disciplined, investor-ready</strong>
          </article>
        </div>
      </div>
    </section>

    <section class="band-a">
      <div>
        <span class="mono">01</span>
        <h3>Open the product page</h3>
        <p>Move from the brand story into the actual product without a jarring design jump.</p>
      </div>
      <div>
        <span class="mono">02</span>
        <h3>Review live match rooms</h3>
        <p>Jump into real demos with annotated clips, possession context, and heatmaps already staged.</p>
      </div>
      <div>
        <span class="mono">03</span>
        <h3>Return to the archive</h3>
        <p>The landing direction stays aligned with the app once users move deeper into the product.</p>
      </div>
    </section>

    <section class="surface-card narrative-a">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Narrative fit</span>
          <h2>For premium demos and top-of-funnel calls</h2>
        </div>
        <p>
          This direction works best when you want Korner Flags to feel like a polished, modern
          sports intelligence product before the viewer even reaches the app.
        </p>
      </div>

      <div class="narrative-grid">
        <article>
          <p>Visual language</p>
          <h3>Dark stage, brighter signal, tighter contrast.</h3>
        </article>
        <article>
          <p>Conversion path</p>
          <h3>Drive directly into the product page, then into matches or the dashboard.</h3>
        </article>
        <article>
          <p>Best follow-up</p>
          <h3>Use the archive after the first product click to show scale beyond the hero room.</h3>
        </article>
      </div>

      <div class="button-row">
        <a class="button-primary" href={productPage}>Go to product page</a>
        <a class="button-secondary" href={matchesPage}>Open past matches</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .landing-page-a {
    display: grid;
    gap: 30px;
  }

  .hero-a {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
    gap: 24px;
    padding: 36px;
    border-radius: 38px;
    background:
      radial-gradient(circle at 80% 16%, rgba(97, 168, 241, 0.26), transparent 18%),
      radial-gradient(circle at 18% 84%, rgba(35, 70, 110, 0.32), transparent 22%),
      linear-gradient(145deg, #07111d, #0e2136 55%, #153557);
    color: white;
    box-shadow: 0 36px 72px rgba(8, 17, 29, 0.18);
  }

  .hero-copy h1 {
    max-width: 10ch;
    margin: 18px 0 0;
    font-size: clamp(3.2rem, 6.2vw, 5.8rem);
    line-height: 0.92;
  }

  .hero-copy p {
    max-width: 620px;
    margin: 22px 0 0;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.8;
    font-size: 1.06rem;
  }

  .hero-copy .button-row {
    margin-top: 28px;
  }

  .stage-a {
    display: grid;
    gap: 16px;
    align-content: end;
  }

  .signal-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .signal-card {
    padding: 22px;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
    backdrop-filter: blur(10px);
  }

  .signal-card.main {
    min-height: 260px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .signal-card p {
    margin: 0 0 12px;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .signal-card h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 2.25rem;
    letter-spacing: -0.05em;
    line-height: 0.98;
  }

  .signal-card strong {
    font-size: 1.05rem;
    line-height: 1.55;
  }

  .signal-card span {
    display: block;
    margin-top: 16px;
    color: rgba(255, 255, 255, 0.76);
    line-height: 1.68;
  }

  .band-a {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .band-a div {
    padding: 24px;
    border-radius: 26px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(240, 244, 248, 0.88));
    border: var(--border-subtle);
    box-shadow: var(--shadow-card);
  }

  .band-a span {
    color: var(--steel-700);
    font-size: 0.86rem;
  }

  .band-a h3 {
    margin: 16px 0 0;
    color: var(--ink-900);
    font-size: 1.16rem;
    line-height: 1.4;
  }

  .band-a p {
    margin: 12px 0 0;
    color: var(--slate-600);
    line-height: 1.72;
  }

  .narrative-a {
    padding: 30px;
  }

  .narrative-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .narrative-grid article {
    padding: 22px;
    border-radius: 22px;
    background: linear-gradient(180deg, rgba(245, 248, 252, 0.96), rgba(235, 241, 247, 0.92));
    border: var(--border-subtle);
  }

  .narrative-grid p {
    margin: 0 0 10px;
    color: var(--steel-700);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .narrative-grid h3 {
    margin: 0;
    color: var(--ink-900);
    font-size: 1.08rem;
    line-height: 1.6;
  }

  .narrative-a .button-row {
    margin-top: 22px;
  }

  @media (max-width: 1080px) {
    .hero-a,
    .band-a,
    .narrative-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .hero-a,
    .narrative-a {
      padding: 22px;
    }

    .signal-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy h1 {
      font-size: clamp(2.8rem, 12vw, 4.8rem);
    }
  }
</style>
