---
import BaseLayout from "../layouts/BaseLayout.astro";
import KornerLogo from "../components/KornerLogo.astro";
import manifestData from "../../public/data/manifest.json";
import { clipThumbnail, clipTitle, withBase } from "../lib/site";

const productPage = `${import.meta.env.BASE_URL}product/`;
const dashboardPage = `${import.meta.env.BASE_URL}dashboard/`;
const matchesPage = `${import.meta.env.BASE_URL}matches/`;
const otherOption = `${import.meta.env.BASE_URL}landing-option-a/`;

const clips = manifestData.clips || [];
const heroClip = clips[0];
const supportClip = clips[1] || clips[0];

const heroImage = withBase(clipThumbnail(heroClip));
const supportImage = withBase(clipThumbnail(supportClip));
const heatmapOne = withBase(heroClip?.heatmap_team1_url || "");
const heatmapTwo = withBase(supportClip?.heatmap_team2_url || "");
---

<BaseLayout
  title="Korner Flags | Landing option B"
  description="Modern landing-page option B for Korner Flags."
  activeNav="home"
>
  <div class="page landing-page-b">
    <section class="hero-b">
      <div class="hero-copy">
        <div class="hero-brand">
          <KornerLogo size={72} rounded={22} />
          <div>
            <span class="eyebrow">Landing option B</span>
            <p class="brand-note">Sharper type, stronger brand presence, and a field-led story.</p>
          </div>
        </div>

        <h1 class="display">Scroll the pitch. Let the analytics orbit the game.</h1>
        <p>
          This version turns the landing page into a product scene. The pitch rotates while match
          imagery, heatmaps, and tactical signals gather around it, so the brand feels like a real
          soccer analysis system instead of another generic SaaS page.
        </p>

        <div class="button-row">
          <a class="button-primary" href={productPage}>Enter product page</a>
          <a class="button-secondary" href={otherOption}>See option A</a>
        </div>
      </div>

      <aside class="hero-stack">
        <article class="hero-panel hero-panel-main">
          <img src={heroImage} alt={`${clipTitle(heroClip)} thumbnail`} loading="eager" />
          <div class="hero-panel-copy">
            <p>Featured room</p>
            <h2>{clipTitle(heroClip)}</h2>
          </div>
        </article>

        <div class="hero-mini-grid">
          <article class="hero-mini">
            <img src={heatmapOne} alt="Team heatmap preview" loading="lazy" />
            <span>Movement density treated like product imagery</span>
          </article>
          <article class="hero-mini hero-mini-logo">
            <KornerLogo size={92} rounded={28} />
            <span>The mark belongs inside the experience, not just in the nav.</span>
          </article>
        </div>
      </aside>
    </section>

    <section class="field-experience" id="field-experience" data-field-experience>
      <div class="field-copy">
        <span class="eyebrow">Field narrative</span>
        <h2 class="display">A scrollable soccer field that turns as the product comes into focus.</h2>
        <p>
          The central pitch tilts and settles during scroll, while match imagery and analytics sit
          around it like live briefing material. It gives the page spatial structure instead of
          stacking more cards on a flat canvas.
        </p>

        <div class="field-steps">
          <article>
            <span class="mono">01</span>
            <strong>Lead with the mark</strong>
            <p>The logo carries the same soft-spectrum color story across the whole page.</p>
          </article>
          <article>
            <span class="mono">02</span>
            <strong>Turn the pitch</strong>
            <p>The field rotates from dramatic to readable as the surrounding analytics stabilize.</p>
          </article>
          <article>
            <span class="mono">03</span>
            <strong>Convert into product</strong>
            <p>From here the user moves straight into the product page, dashboard, or match archive.</p>
          </article>
        </div>
      </div>

      <div class="field-stage">
        <div class="field-board">
          <div class="field-orbit orbit-left-top">
            <article class="analytics-card image-card">
              <img src={heatmapOne} alt="Heatmap detail" loading="lazy" />
              <div>
                <p>Heat concentration</p>
                <strong>Advanced pressing density mapped as a tactical layer</strong>
              </div>
            </article>
          </div>

          <div class="field-orbit orbit-right-top">
            <article class="analytics-card stat-card">
              <p>Possession edge</p>
              <strong>62.1%</strong>
              <span>Signals stay close to the pitch so the page reads like a match briefing.</span>
            </article>
          </div>

          <div class="field-orbit orbit-left-bottom">
            <article class="analytics-card image-card small">
              <img src={supportImage} alt={`${clipTitle(supportClip)} thumbnail`} loading="lazy" />
              <div>
                <p>Second room</p>
                <strong>{clipTitle(supportClip)}</strong>
              </div>
            </article>
          </div>

          <div class="field-orbit orbit-right-bottom">
            <article class="analytics-card stat-card accent">
              <p>Archive ready</p>
              <strong>2 live demos</strong>
              <span>Product page, dashboard, and past matches all sit behind the same branded front door.</span>
            </article>
          </div>

          <div class="pitch-shell">
            <div class="pitch-glow"></div>
            <div class="pitch-plane">
              <div class="pitch-lines">
                <div class="pitch-center-line"></div>
                <div class="center-circle"></div>
                <div class="penalty-box top"></div>
                <div class="penalty-box bottom"></div>
                <div class="goal-box top"></div>
                <div class="goal-box bottom"></div>
                <div class="center-mark"></div>
              </div>

              <div class="pitch-badge">
                <KornerLogo size={88} rounded={28} />
                <div>
                  <p>Korner Flags</p>
                  <strong>Coach-facing match intelligence</strong>
                </div>
              </div>

              <div class="pitch-overlay top-left">
                <span class="mono">Pass review</span>
              </div>
              <div class="pitch-overlay top-right">
                <span class="mono">Heatmaps</span>
              </div>
              <div class="pitch-overlay bottom-left">
                <span class="mono">Movement</span>
              </div>
              <div class="pitch-overlay bottom-right">
                <span class="mono">Analysis room</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="gallery-band">
      <article class="gallery-card large">
        <img src={heroImage} alt={`${clipTitle(heroClip)} visual`} loading="lazy" />
        <div>
          <p>Match imagery</p>
          <h3>Real clip visuals keep the product story grounded in the game itself.</h3>
        </div>
      </article>

      <article class="gallery-card">
        <img src={heatmapTwo} alt="Heatmap visual" loading="lazy" />
        <div>
          <p>Analytics image</p>
          <h3>Heatmaps show up as premium artifacts instead of looking like dumped charts.</h3>
        </div>
      </article>

      <article class="gallery-card copy-card">
        <p>Brand fit</p>
        <h3>The logo now appears in the shell, in the hero, and at the center of the field.</h3>
        <span>
          That keeps the identity integrated into the interaction model instead of acting like a
          decorative icon pasted over the top.
        </span>
      </article>
    </section>

    <section class="surface-card framework-b">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Conversion path</span>
          <h2>Landing page energy, product-page discipline</h2>
        </div>
        <p>
          This route stays expressive at the top, then hands off cleanly into the real product
          surfaces: the product page, dashboard, and live match archive.
        </p>
      </div>

      <div class="framework-grid">
        <article>
          <span class="mono">Product</span>
          <h3>Open the actual review page with featured clips and the full demo flow.</h3>
        </article>
        <article>
          <span class="mono">Dashboard</span>
          <h3>Move into recent analyses without losing the visual identity of the brand page.</h3>
        </article>
        <article>
          <span class="mono">Archive</span>
          <h3>Show the historical match library as a real workflow, not as a side note.</h3>
        </article>
      </div>

      <div class="button-row">
        <a class="button-primary" href={productPage}>Go to product page</a>
        <a class="button-secondary" href={dashboardPage}>Open dashboard</a>
        <a class="button-secondary" href={matchesPage}>See past matches</a>
      </div>
    </section>
  </div>
</BaseLayout>

<script is:inline>
  const section = document.getElementById("field-experience");
  if (section) {
    const updateFieldProgress = () => {
      const rect = section.getBoundingClientRect();
      const total = Math.max(section.offsetHeight - window.innerHeight, 1);
      const progress = Math.min(Math.max(-rect.top / total, 0), 1);
      section.style.setProperty("--field-progress", progress.toFixed(3));
    };

    updateFieldProgress();
    window.addEventListener("scroll", updateFieldProgress, { passive: true });
    window.addEventListener("resize", updateFieldProgress);
  }
</script>

<style>
  .landing-page-b {
    --field-progress: 0;
    display: grid;
    gap: 34px;
  }

  .landing-page-b :global(.topbar-inner) {
    background: rgba(10, 22, 39, 0.92);
  }

  .hero-b {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
    gap: 26px;
    padding: 34px;
    border-radius: 40px;
    background:
      radial-gradient(circle at 10% 12%, rgba(203, 248, 161, 0.28), transparent 22%),
      radial-gradient(circle at 88% 18%, rgba(76, 128, 223, 0.26), transparent 22%),
      linear-gradient(135deg, #08111d 0%, #0f2640 46%, #172c57 100%);
    color: white;
    overflow: hidden;
    box-shadow: 0 36px 74px rgba(8, 17, 29, 0.22);
  }

  .hero-brand {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .brand-note {
    margin: 10px 0 0;
    color: rgba(255, 255, 255, 0.64);
    max-width: 28ch;
    line-height: 1.5;
  }

  .hero-copy h1 {
    margin: 22px 0 0;
    max-width: 9.8ch;
    font-size: clamp(3.5rem, 6.6vw, 6.2rem);
    line-height: 0.91;
    letter-spacing: -0.08em;
  }

  .hero-copy p {
    max-width: 640px;
    margin: 22px 0 0;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.82;
    font-size: 1.05rem;
  }

  .hero-copy .button-row {
    margin-top: 30px;
  }

  .hero-stack {
    display: grid;
    gap: 16px;
    align-content: stretch;
  }

  .hero-panel,
  .hero-mini {
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(14px);
  }

  .hero-panel-main {
    min-height: 360px;
  }

  .hero-panel-main img,
  .hero-mini img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-panel-main:after,
  .hero-mini:after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 20%, rgba(7, 16, 29, 0.84) 100%);
    pointer-events: none;
  }

  .hero-panel-copy,
  .hero-mini span {
    position: absolute;
    left: 18px;
    right: 18px;
    bottom: 18px;
    z-index: 1;
  }

  .hero-panel-copy p {
    margin: 0 0 8px;
    color: rgba(255, 255, 255, 0.64);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-panel-copy h2 {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.1;
  }

  .hero-mini-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .hero-mini {
    min-height: 180px;
  }

  .hero-mini span {
    color: white;
    line-height: 1.45;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .hero-mini-logo {
    display: grid;
    place-items: center;
    padding: 22px;
    text-align: center;
    background:
      radial-gradient(circle at top left, rgba(198, 248, 156, 0.26), transparent 26%),
      radial-gradient(circle at bottom right, rgba(76, 128, 223, 0.26), transparent 28%),
      rgba(255, 255, 255, 0.08);
  }

  .hero-mini-logo:after {
    background: linear-gradient(180deg, transparent 0%, rgba(10, 20, 34, 0.24) 100%);
  }

  .hero-mini-logo span {
    position: static;
    margin-top: 16px;
    max-width: 18ch;
  }

  .field-experience {
    display: grid;
    grid-template-columns: minmax(280px, 0.75fr) minmax(0, 1.25fr);
    gap: 26px;
    min-height: 220vh;
    position: relative;
  }

  .field-copy {
    padding: 18px 0;
  }

  .field-copy h2 {
    margin: 16px 0 0;
    color: var(--ink-900);
    font-size: clamp(2.3rem, 4vw, 4rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
    max-width: 12ch;
  }

  .field-copy > p {
    margin: 22px 0 0;
    color: var(--slate-600);
    line-height: 1.82;
    max-width: 38ch;
    font-size: 1rem;
  }

  .field-steps {
    display: grid;
    gap: 14px;
    margin-top: 26px;
  }

  .field-steps article {
    padding: 18px 18px 16px;
    border-radius: 20px;
    border: var(--border-subtle);
    background: rgba(255, 255, 255, 0.78);
    box-shadow: var(--shadow-card);
  }

  .field-steps span {
    color: var(--steel-700);
    font-size: 0.8rem;
  }

  .field-steps strong {
    display: block;
    margin-top: 12px;
    color: var(--ink-900);
    font-size: 1rem;
  }

  .field-steps p {
    margin: 8px 0 0;
    color: var(--slate-600);
    line-height: 1.65;
  }

  .field-stage {
    position: sticky;
    top: 104px;
    min-height: calc(100vh - 124px);
    display: grid;
    align-items: center;
  }

  .field-board {
    position: relative;
    min-height: min(78vh, 760px);
    display: grid;
    place-items: center;
  }

  .pitch-shell {
    position: relative;
    width: min(68vw, 760px);
    aspect-ratio: 1 / 1.04;
    display: grid;
    place-items: center;
  }

  .pitch-glow {
    position: absolute;
    inset: 8% 10%;
    border-radius: 36px;
    background:
      radial-gradient(circle at 12% 16%, rgba(194, 243, 139, 0.54), transparent 24%),
      radial-gradient(circle at 86% 18%, rgba(69, 123, 221, 0.42), transparent 24%),
      radial-gradient(circle at 62% 84%, rgba(47, 150, 178, 0.28), transparent 18%);
    filter: blur(26px);
    transform: scale(calc(1 + var(--field-progress) * 0.06));
    opacity: calc(0.72 + var(--field-progress) * 0.22);
  }

  .pitch-plane {
    position: relative;
    width: 100%;
    aspect-ratio: 0.98 / 1.1;
    border-radius: 34px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.1), transparent 18%),
      linear-gradient(180deg, #0d7c5f 0%, #0f6d58 56%, #0b5046 100%);
    box-shadow:
      0 30px 80px rgba(10, 35, 34, 0.26),
      inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    transform-style: preserve-3d;
    transform:
      perspective(1600px)
      rotateX(calc(24deg - var(--field-progress) * 20deg))
      rotateZ(calc(-14deg + var(--field-progress) * 14deg))
      translateY(calc(var(--field-progress) * -12px));
    transition: transform 120ms linear;
    overflow: hidden;
  }

  .pitch-plane:before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.02) 0,
        rgba(255, 255, 255, 0.02) 14%,
        rgba(255, 255, 255, 0.055) 14%,
        rgba(255, 255, 255, 0.055) 28%
      );
    opacity: 0.4;
  }

  .pitch-lines,
  .pitch-center-line,
  .center-circle,
  .penalty-box,
  .goal-box,
  .center-mark {
    position: absolute;
  }

  .pitch-lines {
    inset: 6%;
    border-radius: 24px;
    border: 2px solid rgba(255, 255, 255, 0.86);
  }

  .pitch-center-line {
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.86);
  }

  .center-circle {
    left: 50%;
    top: 50%;
    width: 24%;
    aspect-ratio: 1;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    border: 2px solid rgba(255, 255, 255, 0.86);
  }

  .center-mark {
    left: 50%;
    top: 50%;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    background: rgba(255, 255, 255, 0.92);
  }

  .penalty-box {
    left: 50%;
    width: 44%;
    height: 18%;
    transform: translateX(-50%);
    border: 2px solid rgba(255, 255, 255, 0.86);
  }

  .penalty-box.top {
    top: 0;
    border-bottom: none;
  }

  .penalty-box.bottom {
    bottom: 0;
    border-top: none;
  }

  .goal-box {
    left: 50%;
    width: 24%;
    height: 8%;
    transform: translateX(-50%);
    border: 2px solid rgba(255, 255, 255, 0.86);
  }

  .goal-box.top {
    top: 0;
    border-bottom: none;
  }

  .goal-box.bottom {
    bottom: 0;
    border-top: none;
  }

  .pitch-badge {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%) translateZ(40px);
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 18px 20px;
    border-radius: 26px;
    background: rgba(8, 22, 37, 0.68);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 24px 48px rgba(5, 13, 25, 0.26);
    backdrop-filter: blur(18px);
  }

  .pitch-badge p {
    margin: 0 0 8px;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pitch-badge strong {
    color: white;
    font-size: 1.02rem;
    line-height: 1.45;
  }

  .pitch-overlay {
    position: absolute;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: white;
    backdrop-filter: blur(12px);
  }

  .pitch-overlay.top-left {
    left: 9%;
    top: 10%;
  }

  .pitch-overlay.top-right {
    right: 9%;
    top: 12%;
  }

  .pitch-overlay.bottom-left {
    left: 10%;
    bottom: 12%;
  }

  .pitch-overlay.bottom-right {
    right: 9%;
    bottom: 10%;
  }

  .field-orbit {
    position: absolute;
    width: min(22vw, 260px);
    z-index: 2;
  }

  .orbit-left-top {
    left: 2%;
    top: 8%;
    transform: translateY(calc(var(--field-progress) * -44px));
  }

  .orbit-right-top {
    right: 0;
    top: 10%;
    transform: translateY(calc(var(--field-progress) * -28px));
  }

  .orbit-left-bottom {
    left: 6%;
    bottom: 8%;
    transform: translateY(calc(var(--field-progress) * 24px));
  }

  .orbit-right-bottom {
    right: 4%;
    bottom: 12%;
    transform: translateY(calc(var(--field-progress) * 36px));
  }

  .analytics-card {
    padding: 16px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.68);
    box-shadow: 0 24px 46px rgba(14, 39, 66, 0.14);
    backdrop-filter: blur(18px);
  }

  .analytics-card p {
    margin: 0 0 8px;
    color: var(--steel-700);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .analytics-card strong {
    display: block;
    color: var(--ink-900);
    font-size: 1.05rem;
    line-height: 1.48;
  }

  .analytics-card span {
    display: block;
    margin-top: 10px;
    color: var(--slate-600);
    line-height: 1.6;
    font-size: 0.92rem;
  }

  .image-card {
    padding: 0;
    overflow: hidden;
  }

  .image-card img {
    width: 100%;
    aspect-ratio: 1.18;
    object-fit: cover;
  }

  .image-card div {
    padding: 15px 16px 16px;
  }

  .image-card.small img {
    aspect-ratio: 1.3;
  }

  .stat-card {
    min-height: 180px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .stat-card strong {
    font-size: 2.3rem;
    letter-spacing: -0.07em;
  }

  .stat-card.accent {
    background:
      radial-gradient(circle at top left, rgba(198, 248, 156, 0.34), transparent 34%),
      rgba(255, 255, 255, 0.82);
  }

  .gallery-band {
    display: grid;
    gap: 18px;
    grid-template-columns: 1.2fr 1fr 0.9fr;
  }

  .gallery-card {
    overflow: hidden;
    border-radius: 28px;
    border: var(--border-subtle);
    background: rgba(255, 255, 255, 0.88);
    box-shadow: var(--shadow-card);
  }

  .gallery-card img {
    width: 100%;
    height: 100%;
    max-height: 300px;
    object-fit: cover;
  }

  .gallery-card.large img {
    max-height: 360px;
  }

  .gallery-card div,
  .copy-card {
    padding: 20px 22px 22px;
  }

  .gallery-card p,
  .copy-card p {
    margin: 0 0 10px;
    color: var(--steel-700);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .gallery-card h3,
  .copy-card h3 {
    margin: 0;
    color: var(--ink-900);
    font-size: 1.22rem;
    line-height: 1.55;
  }

  .copy-card span {
    display: block;
    margin-top: 14px;
    color: var(--slate-600);
    line-height: 1.75;
  }

  .framework-b {
    padding: 30px;
  }

  .framework-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .framework-grid article {
    padding: 22px;
    border-radius: 22px;
    border: var(--border-subtle);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(240, 244, 248, 0.88));
  }

  .framework-grid span {
    color: var(--steel-700);
    font-size: 0.82rem;
  }

  .framework-grid h3 {
    margin: 14px 0 0;
