---
import BaseLayout from "../layouts/BaseLayout.astro";
import manifestData from "../../public/data/manifest.json";
import { clipTitle, formatDuration, safeNumber } from "../lib/site";

const clips = manifestData.clips || [];
const featuredClip = clips[0];
const featuredHref = featuredClip
  ? `${import.meta.env.BASE_URL}clips/${featuredClip.clip_id}/`
  : `${import.meta.env.BASE_URL}matches/`;
const totalMinutes = Math.round(
  clips.reduce((sum: number, clip: Record<string, any>) => sum + safeNumber(clip.duration_seconds), 0) / 60,
);
---

<BaseLayout
  title="Korner Flags | Dashboard"
  description="Recent analyses and product entry points for Korner Flags."
  activeNav="dashboard"
>
  <div class="page dashboard-page">
    <section class="dashboard-hero">
      <div>
        <span class="eyebrow">Dashboard</span>
        <h1 class="display">The product home for match review.</h1>
        <p>
          Open the latest analysis, return to past matches, or move into package selection without
          leaving the same product system.
        </p>
      </div>

      <div class="dashboard-actions">
        <a class="button-primary" href={featuredHref}>
          Open latest room
        </a>
        <a class="button-secondary" href={`${import.meta.env.BASE_URL}matches/`}>View past matches</a>
      </div>
    </section>

    <section class="metric-grid">
      <div class="metric-card">
        <span>Recent matches</span>
        <strong>{clips.length}</strong>
        <p>Demo library currently available for coach walkthroughs and stakeholder presentations.</p>
      </div>
      <div class="metric-card">
        <span>Processed footage</span>
        <strong>{totalMinutes} min</strong>
        <p>All clips are ready to open immediately with annotated playback already in place.</p>
      </div>
      <div class="metric-card">
        <span>Current plan</span>
        <strong>Investor demo</strong>
        <p>Focus is on a polished product story, measured claims, and clean end-to-end presentation.</p>
      </div>
    </section>

    <section class="surface-card dashboard-panel">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Recent analyses</span>
          <h2>Open the rooms that matter most</h2>
        </div>
        <p>
          This hub prioritizes the clips most useful in meetings: the flagship room, the archive,
          and the checkout path for a more complete paid workflow.
        </p>
      </div>

      <div class="analysis-list">
        {clips.map((clip, index) => (
          <article class="analysis-row">
            <div>
              <p>{index === 0 ? "Featured analysis" : "Analysis room"}</p>
              <h3>{clipTitle(clip)}</h3>
            </div>
            <div class="analysis-meta">
              <span class="mono">{formatDuration(clip.duration_seconds)}</span>
              <a href={`${import.meta.env.BASE_URL}clips/${clip.clip_id}/`}>Open room</a>
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .dashboard-page {
    display: grid;
    gap: 28px;
  }

  .dashboard-hero {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    padding: 30px 32px;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(107, 160, 216, 0.22), transparent 30%),
      linear-gradient(135deg, var(--ink-900), var(--ink-700));
    color: white;
  }

  .dashboard-hero h1 {
    margin: 16px 0 0;
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    line-height: 0.98;
  }

  .dashboard-hero p {
    margin: 18px 0 0;
    max-width: 640px;
    color: rgba(255, 255, 255, 0.76);
    line-height: 1.75;
  }

  .dashboard-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .dashboard-panel {
    padding: 28px;
  }

  .analysis-list {
    display: grid;
    gap: 14px;
  }

  .analysis-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 20px;
    border-radius: 20px;
    border: var(--border-subtle);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(240, 244, 248, 0.88));
  }

  .analysis-row p {
    margin: 0 0 8px;
    color: var(--steel-700);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .analysis-row h3 {
    margin: 0;
    color: var(--ink-900);
    font-size: 1.16rem;
  }

  .analysis-meta {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .analysis-meta span {
    color: var(--slate-500);
  }

  .analysis-meta a {
    color: var(--steel-700);
    font-weight: 800;
  }

  @media (max-width: 860px) {
    .dashboard-hero,
    .analysis-row {
      flex-direction: column;
      align-items: stretch;
    }

    .analysis-meta {
      justify-content: space-between;
    }
  }
</style>
