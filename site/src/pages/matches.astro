---
import KfLayout from "../layouts/KfLayout.astro";
const base = import.meta.env.BASE_URL;

const matches = [
  { home: "NC State", away: "Washington", date: "Apr 6, 2026", score: "1–0", poss: 54, dist: "67.4", clips: 8, status: "Ready" },
  { home: "NC State", away: "Duke", date: "Mar 29, 2026", score: "2–2", poss: 61, dist: "71.2", clips: 11, status: "Ready" },
  { home: "NC State", away: "Clemson", date: "Mar 15, 2026", score: "0–1", poss: 49, dist: "64.8", clips: 6, status: "Ready" },
  { home: "U19", away: "Scrimmage", date: "Mar 21, 2026", score: "3–1", poss: 58, dist: "59.1", clips: 9, status: "Processing" },
];
---
<KfLayout title="Past matches — Korner Flag" active="">
  <section class="page-shell">
    <div class="container">
      <div class="page-head reveal in">
        <div>
          <span class="eyebrow">Library</span>
          <h1>Past matches.</h1>
          <p class="muted">Every analysis you've run, ready to reopen and share.</p>
        </div>
        <a class="btn btn-primary btn-lg" href={`${base}login/`}>Analyze a new match</a>
      </div>

      <div class="match-grid">
        {matches.map((m, i) => (
          <a class="lcard mcard reveal" data-d={(i % 4) + 1} href={m.status === "Ready" ? `${base}room/` : "#"}>
            <div class="mcard-thumb">
              <span class="mcard-pitch"></span>
              <span class:list={["mstatus", m.status === "Ready" ? "ok" : "wait"]}>{m.status}</span>
              <span class="mcard-score">{m.score}</span>
            </div>
            <div class="mcard-body">
              <b>{m.home} <span class="vs">vs</span> {m.away}</b>
              <small>{m.date}</small>
              <div class="mcard-stats">
                <span><i>Poss</i>{m.poss}%</span>
                <span><i>Dist</i>{m.dist} km</span>
                <span><i>Clips</i>{m.clips}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</KfLayout>

<style is:global>
  .match-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 38px; }
  .mcard { overflow: hidden; transition: transform .25s var(--ease), box-shadow .25s var(--ease), border-color .25s; }
  .mcard:hover { transform: translateY(-4px); box-shadow: var(--sh); border-color: rgba(16,24,34,.16); }
  .mcard-thumb { position: relative; aspect-ratio: 16/7.5; background: linear-gradient(160deg,#13402b,#0c2a1d); overflow: hidden; }
  .mcard-pitch { position: absolute; inset: 16px; border: 1px solid rgba(255,255,255,.18); border-radius: 6px; }
  .mcard-pitch::before { content: ""; position: absolute; left: 50%; top: 0; bottom: 0; width: 1px; background: rgba(255,255,255,.18); }
  .mcard-pitch::after { content: ""; position: absolute; left: 50%; top: 50%; width: 38px; height: 38px; border: 1px solid rgba(255,255,255,.18); border-radius: 50%; transform: translate(-50%,-50%); }
  .mcard-thumb .mstatus { position: absolute; top: 12px; left: 12px; }
  .mcard-score { position: absolute; top: 12px; right: 14px; font-family: var(--font-display); font-weight: 600; font-size: 16px; color: #fff; }
  .mcard-body { padding: 16px 18px 18px; }
  .mcard-body b { font-family: var(--font-display); font-weight: 600; font-size: 16px; }
  .mcard-body .vs { color: var(--text-3); font-weight: 500; }
  .mcard-body small { display: block; color: var(--text-3); font-size: 12.5px; margin-top: 3px; }
  .mcard-stats { display: flex; gap: 20px; margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--border-2); }
  .mcard-stats span { font-family: var(--font-display); font-weight: 600; font-size: 14px; display: flex; flex-direction: column; gap: 2px; }
  .mcard-stats i { font-family: var(--font-body); font-style: normal; font-size: 10.5px; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; color: var(--text-3); }
  @media (max-width: 760px) { .match-grid { grid-template-columns: 1fr; } }
</style>
