---
import KfLayout from "../../layouts/KfLayout.astro";
import VideoTrackingHero from "../../components/landing/VideoTrackingHero.astro";
---

<KfLayout title="Match tracking hero — scroll prototype">
  <VideoTrackingHero />

  <!-- scaffold notes (scrolls in after the pinned hero releases) -->
  <section class="section">
    <div class="container" style="max-width:760px">
      <span class="eyebrow">Scaffold</span>
      <h2 style="margin-top:14px">How this scroll hero is wired</h2>
      <ul class="vth-notes">
        <li><b>Component:</b> <code>site/src/components/landing/VideoTrackingHero.astro</code> — pins for 300vh, crossfades 6 frames, and drives the SVG tracking overlay with GSAP ScrollTrigger. Respects <code>prefers-reduced-motion</code> (no pin; final goal frame shown statically).</li>
        <li><b>Data:</b> <code>site/src/data/heroTrackingSequence.ts</code> — the 6 scroll beats. <b>Edit each state's <code>marker</code> (x,y %)</b> to reposition the tracking circle; edit state 3's <code>passLine</code> to re-aim the pass.</li>
        <li><b>Frames:</b> <code>site/public/images/sequence/img1–6.webp</code> (compressed from the source PNGs).</li>
      </ul>
    </div>
  </section>
</KfLayout>

<style is:global>
  .vth-notes { margin-top: 18px; padding-left: 18px; display: flex; flex-direction: column; gap: 12px; color: var(--text-2, #4A5A70); line-height: 1.6; }
  .vth-notes code { background: var(--surface-2, #f0f4f8); padding: 1px 6px; border-radius: 5px; font-size: 13px; }
</style>
