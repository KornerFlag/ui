---
/**
 * ScrollNext — circular down-arrow at the bottom center of a section,
 * advancing to the next one. Anchor clicks are driven by the smooth-scroll
 * handler in KfLayout (snap suspended mid-flight). `dark` flips the palette
 * for photo/band sections. The parent section must be position: relative.
 */
const { to, dark = false, label = "Scroll to next section" } = Astro.props;
---
<a class={`scroll-next ${dark ? "dark" : ""}`} href={`#${to}`} aria-label={label}>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
</a>

<style>
  .scroll-next { position: absolute; left: 50%; bottom: 20px; translate: -50% 0; z-index: 5;
    display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%;
    color: var(--ink); border: 1px solid rgba(25,25,20,.22); background: transparent; opacity: .55;
    transition: opacity .3s var(--ease), background .3s var(--ease), color .3s var(--ease), border-color .3s var(--ease), transform .3s var(--ease); }
  .scroll-next svg { width: 15px; height: 15px; }
  .scroll-next:hover { opacity: 1; background: var(--ink); color: #fff; border-color: var(--ink); transform: translateY(3px); }
  .scroll-next.dark { color: #fff; border-color: rgba(255,255,255,.4); background: rgba(14,22,10,.25); backdrop-filter: blur(6px); }
  .scroll-next.dark:hover { opacity: 1; background: #fff; color: var(--green-deep); border-color: #fff; }
  @media (max-width: 640px) { .scroll-next { width: 34px; height: 34px; bottom: 12px; } }
</style>
