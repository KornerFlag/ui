---
import { withBase } from "../../lib/site";
import { heroTrackingSequence } from "../../data/heroTrackingSequence";

/**
 * VideoTrackingHero — scroll-controlled frame-sequence hero.
 *
 * Pins for 300vh and crossfades the 6 frames while a GSAP timeline glides the
 * SVG tracking circle, draws the progressive pass line, counts up possession,
 * swaps the event pill, and fades in the heatmap. Respects prefers-reduced-motion
 * (no pin — final goal frame shown with static overlay).
 *
 * Tune the analytics overlay (circle positions, pass line) in
 * src/data/heroTrackingSequence.ts — never here.
 */

const {
  headline = "World Cup-level match analysis for your team.",
  subhead =
    "KornerFlag turns existing footage into passing, possession, movement, heatmaps, and review clips — no wearables or player setup.",
  ctaPrimaryLabel = "Analyze a match",
  ctaPrimaryHref = `${import.meta.env.BASE_URL}login/`,
  ctaSecondaryLabel = "Free one-match analysis",
  ctaSecondaryHref = `${import.meta.env.BASE_URL}contact/`,
} = Astro.props;

const frames = heroTrackingSequence.map((s) => ({
  ...s,
  src: withBase(s.image),
}));
const first = heroTrackingSequence[0];
---

<section class="vth" aria-label="KornerFlag match-tracking hero">
  <!-- 1 · frame stack (crossfaded) -->
  <div class="vth-frames">
    {frames.map((f, i) => (
      <img
        class:list={["vth-frame", { "is-active": i === 0 }]}
        data-frame={i}
        src={f.src}
        alt={f.alt}
        loading={i === 0 ? "eager" : "lazy"}
        fetchpriority={i === 0 ? "high" : "auto"}
        decoding="async"
        draggable="false"
      />
    ))}
  </div>

  <!-- 2 · green heatmap wash (fades in at goal) -->
  <div class="vth-heatmap" id="vth-heatmap" aria-hidden="true"></div>

  <!-- readability scrims -->
  <div class="vth-scrim" aria-hidden="true"></div>

  <!-- 3 · SVG analytics overlay (matches image object-fit: cover via slice) -->
  <svg
    class="vth-svg"
    viewBox="0 0 1408 768"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <defs>
      <filter id="vthGlow" x="-60%" y="-60%" width="220%" height="220%">
        <feGaussianBlur stdDeviation="9" result="b" />
        <feMerge>
          <feMergeNode in="b" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <!-- progressive pass line (state 3) -->
    <line
      id="vth-passline"
      class="vth-passline"
      x1="0" y1="0" x2="0" y2="0"
      stroke="#38C6FF"
      stroke-width="4"
      stroke-linecap="round"
    />
    <circle id="vth-pass-dot" class="vth-pass-dot" r="7" fill="#38C6FF" />

    <!-- receiver highlight ring (state 4) -->
    <circle
      id="vth-receiver"
      class="vth-receiver"
      r="54"
      fill="none"
      stroke="#7CF2C0"
      stroke-width="3"
      stroke-dasharray="10 9"
    />

    <!-- tracking circle (glides between states) -->
    <g id="vth-tracker" class="vth-tracker">
      <circle class="vth-pulse" id="vth-pulse" r="42" fill="none" stroke="#38C6FF" stroke-width="2" />
      <circle class="vth-ring" r="42" fill="none" stroke="#38C6FF" stroke-width="4" filter="url(#vthGlow)" />
      <circle class="vth-core" r="4.5" fill="#9BE6FF" />
    </g>
  </svg>

  <!-- 4 · HTML overlay: telemetry chrome + hero copy -->
  <div class="vth-ui">
    <!-- player-anchored label (positioned by JS) -->
    <div class="vth-label" id="vth-label" hidden>
      <span class="vth-label-dot"></span>
      <span id="vth-label-text">{first.label}</span>
    </div>

    <div class="vth-hud vth-hud-top">
      <span class="vth-pill" id="vth-event">
        <span class="vth-pill-dot"></span>
        <span id="vth-event-text">{first.event}</span>
      </span>
    </div>

    <div class="vth-hud vth-hud-right">
      <div class="vth-card">
        <span class="vth-card-k">Possession</span>
        <span class="vth-card-v"><b id="vth-poss-num">{first.possession}</b>%</span>
        <span class="vth-bar"><i id="vth-poss-bar" style={`width:${first.possession}%`}></i></span>
      </div>
      <div class="vth-card vth-card-review" id="vth-review" hidden>
        <span class="vth-card-k">Review clips</span>
        <span class="vth-card-v"><b id="vth-review-num">0</b></span>
        <span class="vth-card-note">Saved for coach review</span>
      </div>
    </div>

    <div class="vth-copy">
      <span class="vth-eyebrow">Live match tracking</span>
      <h1 class="vth-headline">{headline}</h1>
      <p class="vth-sub">{subhead}</p>
      <div class="vth-ctas">
        <a class="vth-btn vth-btn-accent" href={ctaPrimaryHref}>
          {ctaPrimaryLabel}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a class="vth-btn vth-btn-ghost" href={ctaSecondaryHref}>{ctaSecondaryLabel}</a>
      </div>
      <span class="vth-scrollhint" aria-hidden="true">Scroll to follow the move</span>
    </div>
  </div>
</section>

<style>
  .vth {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: #0b1626;
    color: #eaf1f9;
    isolation: isolate;
    font-family: 'Manrope', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  /* ---- frame stack ---- */
  .vth-frames { position: absolute; inset: 0; z-index: 0; }
  .vth-frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    will-change: opacity;
    user-select: none;
  }
  .vth-frame.is-active { opacity: 1; }

  /* ---- heatmap wash ---- */
  .vth-heatmap {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0;
    pointer-events: none;
    background:
      radial-gradient(38% 46% at 70% 58%, rgba(43, 211, 122, 0.55), rgba(43, 211, 122, 0) 70%),
      radial-gradient(26% 32% at 52% 52%, rgba(124, 242, 192, 0.35), rgba(124, 242, 192, 0) 72%),
      radial-gradient(30% 38% at 84% 50%, rgba(56, 198, 255, 0.28), rgba(56, 198, 255, 0) 70%);
    mix-blend-mode: screen;
    will-change: opacity;
  }

  /* ---- readability scrims ---- */
  .vth-scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(7, 14, 24, 0.55) 0%, rgba(7, 14, 24, 0) 26%),
      linear-gradient(0deg, rgba(7, 14, 24, 0.82) 0%, rgba(7, 14, 24, 0.12) 42%, rgba(7, 14, 24, 0) 62%),
      linear-gradient(90deg, rgba(7, 14, 24, 0.6) 0%, rgba(7, 14, 24, 0) 46%);
  }

  /* ---- SVG overlay ---- */
  .vth-svg { position: absolute; inset: 0; z-index: 3; width: 100%; height: 100%; pointer-events: none; }

  .vth-tracker { opacity: 0; }
  .vth-passline { stroke-dasharray: 1; stroke-dashoffset: 1; opacity: 0; }
  .vth-pass-dot { opacity: 0; }
  .vth-receiver { opacity: 0; transform-box: fill-box; transform-origin: center; }
  .vth-pulse { opacity: 0; }

  /* ---- HTML overlay ---- */
  .vth-ui { position: absolute; inset: 0; z-index: 4; }

  .vth-label {
    position: absolute;
    top: 0; left: 0;
    transform: translate(-50%, calc(-100% - 16px));
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 11px;
    border-radius: 999px;
    background: rgba(8, 16, 28, 0.82);
    border: 1px solid rgba(56, 198, 255, 0.55);
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(56, 198, 255, 0.12);
    font: 600 13px/1 'IBM Plex Mono', ui-monospace, Menlo, monospace;
    letter-spacing: 0.01em;
    color: #d7f3ff;
    white-space: nowrap;
    pointer-events: none;
    backdrop-filter: blur(6px);
  }
  .vth-label-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #38c6ff;
    box-shadow: 0 0 10px 1px rgba(56, 198, 255, 0.9);
  }

  .vth-hud { position: absolute; padding: clamp(18px, 3vw, 34px); display: flex; gap: 12px; }
  /* clear the fixed 76px site nav so telemetry never tucks under it */
  .vth-hud-top { top: 0; left: 0; padding-top: clamp(90px, 9vh, 108px); }
  .vth-hud-right { top: 0; right: 0; flex-direction: column; align-items: flex-end; padding-top: clamp(90px, 9vh, 108px); }

  /* [hidden] must win over the .vth-card / .vth-label display rules */
  .vth-card[hidden], .vth-label[hidden] { display: none !important; }

  .vth-pill {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 14px; border-radius: 999px;
    background: rgba(8, 16, 28, 0.6);
    border: 1px solid rgba(154, 178, 203, 0.22);
    backdrop-filter: blur(8px);
    font-size: 13px; font-weight: 600; letter-spacing: 0.01em;
    color: #eaf1f9;
  }
  .vth-pill-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #2bd37a;
    box-shadow: 0 0 10px 1px rgba(43, 211, 122, 0.8);
    animation: vth-blink 1.8s ease-in-out infinite;
  }
  @keyframes vth-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

  .vth-card {
    min-width: 150px;
    padding: 13px 15px;
    border-radius: 14px;
    background: rgba(8, 16, 28, 0.62);
    border: 1px solid rgba(154, 178, 203, 0.2);
    backdrop-filter: blur(10px);
    display: flex; flex-direction: column; gap: 6px;
  }
  .vth-card-k { font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #9db2cb; }
  .vth-card-v { font-family: 'IBM Plex Mono', ui-monospace, Menlo, monospace; font-size: 13px; color: #cfe0f2; }
  .vth-card-v b { font-size: 26px; color: #fff; font-weight: 600; letter-spacing: -0.01em; }
  .vth-bar { display: block; height: 5px; border-radius: 999px; background: rgba(154, 178, 203, 0.22); overflow: hidden; }
  .vth-bar i { display: block; height: 100%; border-radius: 999px; background: linear-gradient(90deg, #2c6bb0, #38c6ff); transition: none; }
  .vth-card-review { border-color: rgba(43, 211, 122, 0.4); }
  .vth-card-note { font-size: 11px; color: #8fcdaa; }

  .vth-copy {
    position: absolute;
    left: clamp(18px, 5vw, 72px);
    bottom: clamp(28px, 6vh, 64px);
    max-width: 640px;
  }
  .vth-eyebrow {
    display: inline-block; margin-bottom: 14px;
    font-size: 12px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
    color: #6bd0ff;
  }
  .vth-headline {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 600;
    font-size: clamp(34px, 5vw, 62px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0;
    text-wrap: balance;
  }
  .vth-sub {
    margin: 18px 0 0;
    max-width: 52ch;
    font-size: clamp(15px, 1.5vw, 18px);
    line-height: 1.6;
    color: rgba(234, 241, 249, 0.82);
  }
  .vth-ctas { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 26px; }
  .vth-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 22px; border-radius: 12px;
    font-size: 15px; font-weight: 600; text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }
  .vth-btn svg { width: 18px; height: 18px; }
  .vth-btn-accent {
    background: linear-gradient(180deg, #3d7fc4, #2c6bb0);
    color: #fff;
    box-shadow: 0 10px 30px rgba(44, 107, 176, 0.45);
  }
  .vth-btn-accent:hover { transform: translateY(-1px); box-shadow: 0 14px 36px rgba(44, 107, 176, 0.55); }
  .vth-btn-ghost {
    background: rgba(234, 241, 249, 0.08);
    color: #eaf1f9;
    border: 1px solid rgba(234, 241, 249, 0.22);
    backdrop-filter: blur(6px);
  }
  .vth-btn-ghost:hover { background: rgba(234, 241, 249, 0.14); }

  .vth-scrollhint {
    display: block; margin-top: 24px;
    font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase;
    color: rgba(157, 178, 203, 0.7);
  }
  .vth-scrollhint::before { content: "↓ "; }

  @media (max-width: 720px) {
    .vth-hud-right { flex-direction: column; }
    .vth-card { min-width: 130px; }
    .vth-copy { right: clamp(18px, 5vw, 72px); }
  }

  /* reduced motion: hide live HUD animations (final overlay still shown via JS) */
  @media (prefers-reduced-motion: reduce) {
    .vth-pill-dot { animation: none; }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { heroTrackingSequence } from "../../data/heroTrackingSequence";

  gsap.registerPlugin(ScrollTrigger);

  const W = 1408;
  const H = 768;
  const states = heroTrackingSequence;
  const T = states.length - 1; // transitions

  const stage = document.querySelector<HTMLElement>(".vth");
  if (stage) initHero(stage);

  function toX(p: { x: number; y: number }) { return (p.x / 100) * W; }
  function toY(p: { x: number; y: number }) { return (p.y / 100) * H; }

  function initHero(stage: HTMLElement) {
    const frames = Array.from(stage.querySelectorAll<HTMLImageElement>(".vth-frame"));
    const svg = stage.querySelector<SVGSVGElement>(".vth-svg")!;
    const tracker = stage.querySelector<SVGGElement>("#vth-tracker")!;
    const pulse = stage.querySelector<SVGCircleElement>("#vth-pulse")!;
    const passline = stage.querySelector<SVGLineElement>("#vth-passline")!;
    const passDot = stage.querySelector<SVGCircleElement>("#vth-pass-dot")!;
    const receiver = stage.querySelector<SVGCircleElement>("#vth-receiver")!;

    const labelEl = stage.querySelector<HTMLElement>("#vth-label")!;
    const labelText = stage.querySelector<HTMLElement>("#vth-label-text")!;
    const eventText = stage.querySelector<HTMLElement>("#vth-event-text")!;
    const possNum = stage.querySelector<HTMLElement>("#vth-poss-num")!;
    const possBar = stage.querySelector<HTMLElement>("#vth-poss-bar")!;
    const review = stage.querySelector<HTMLElement>("#vth-review")!;
    const reviewNum = stage.querySelector<HTMLElement>("#vth-review-num")!;

    // tracker position proxy — drives both the SVG group and the HTML label
    const tp = { cx: toX(states[0].marker), cy: toY(states[0].marker) };

    const positionLabel = () => {
      const ctm = svg.getScreenCTM();
      if (!ctm) return;
      const pt = svg.createSVGPoint();
      pt.x = tp.cx; pt.y = tp.cy;
      const scr = pt.matrixTransform(ctm);
      const box = stage.getBoundingClientRect();
      labelEl.style.left = `${scr.x - box.left}px`;
      labelEl.style.top = `${scr.y - box.top}px`;
    };
    const applyTracker = () => {
      gsap.set(tracker, { x: tp.cx, y: tp.cy });
      positionLabel();
    };

    const setText = (i: number) => {
      const s = states[i];
      labelText.textContent = s.label;
      eventText.textContent = s.event;
    };

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // ---- reduced motion: show final goal frame, static overlay, no pin ----
    if (reduce) {
      frames.forEach((f, i) => (f.style.opacity = i === states.length - 1 ? "1" : "0"));
      const last = states.length - 1;
      const goal = states[last];
      tp.cx = toX(goal.marker); tp.cy = toY(goal.marker);
      gsap.set(tracker, { x: tp.cx, y: tp.cy, opacity: 1 });
      setText(last);
      possNum.textContent = String(goal.possession);
      possBar.style.width = `${goal.possession}%`;
      gsap.set(stage.querySelector("#vth-heatmap"), { opacity: 0.55 });
      labelEl.hidden = false;
      positionLabel();
      if (goal.reviewClips) { review.hidden = false; reviewNum.textContent = String(goal.reviewClips); }
      window.addEventListener("resize", positionLabel, { passive: true });
      return;
    }

    // ---- full scroll-driven timeline ----
    labelEl.hidden = false;
    gsap.set(frames[0], { opacity: 1 });
    gsap.set(tracker, { opacity: 1 });
    applyTracker();
    setText(0);

    // independent pulse (not scrubbed)
    gsap.fromTo(
      pulse,
      { attr: { r: 42 }, opacity: 0.55 },
      { attr: { r: 96 }, opacity: 0, duration: 1.7, ease: "power1.out", repeat: -1 },
    );

    const possProxy = { v: states[0].possession };
    const writePoss = () => {
      const v = Math.round(possProxy.v);
      possNum.textContent = String(v);
      possBar.style.width = `${v}%`;
    };

    // state indices used by the timeline + onUpdate
    const passState = states.findIndex((s) => s.passLine);
    const recvState = states.findIndex((s) => s.highlightReceiver);
    const goalState = states.findIndex((s) => s.showHeatmap);

    const tl = gsap.timeline({
      defaults: { ease: "none" },
      scrollTrigger: {
        trigger: stage,
        start: "top top",
        end: "+=300%",
        scrub: 1,
        pin: true,
        anticipatePin: 1,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          // discrete text: snap to nearest state
          const idx = Math.min(T, Math.round(self.progress * T));
          setText(idx);
          // review-clips card appears once the goal beat is reached (reverse-safe)
          const goal = states[goalState];
          if (goalState > 0 && goal?.reviewClips) {
            const reached = idx >= goalState;
            review.hidden = !reached;
            reviewNum.textContent = reached ? String(goal.reviewClips) : "0";
          }
        },
      },
    });

    for (let i = 0; i < T; i++) {
      const pos = i;
      tl.to(frames[i], { opacity: 0, duration: 1 }, pos);
      tl.to(frames[i + 1], { opacity: 1, duration: 1 }, pos);
      tl.to(tp, { cx: toX(states[i + 1].marker), cy: toY(states[i + 1].marker), duration: 1, onUpdate: applyTracker }, pos);
      tl.to(possProxy, { v: states[i + 1].possession, duration: 1, onUpdate: writePoss }, pos);
    }

    // progressive pass line — draws as we arrive at state 3 (index 2), fades after
    if (passState > 0) {
      const pl = states[passState].passLine!;
      const x1 = toX(pl.from), y1 = toY(pl.from), x2 = toX(pl.to), y2 = toY(pl.to);
      const len = Math.hypot(x2 - x1, y2 - y1);
      passline.setAttribute("x1", String(x1));
      passline.setAttribute("y1", String(y1));
      passline.setAttribute("x2", String(x2));
      passline.setAttribute("y2", String(y2));
      passline.style.strokeDasharray = String(len);
      passline.style.strokeDashoffset = String(len);
      passDot.setAttribute("cx", String(x2));
      passDot.setAttribute("cy", String(y2));
      const drawAt = passState - 1; // segment that arrives at the pass state
      tl.to(passline, { opacity: 1, duration: 0.2 }, drawAt + 0.1);
      tl.to(passline, { strokeDashoffset: 0, duration: 0.8 }, drawAt + 0.1);
      tl.to(passDot, { opacity: 1, duration: 0.2 }, drawAt + 0.7);
      tl.to([passline, passDot], { opacity: 0, duration: 0.4 }, passState + 0.4);
    }

    // receiver ring — visible around the final-third entry state
    if (recvState > 0) {
      receiver.setAttribute("cx", String(toX(states[recvState].marker)));
      receiver.setAttribute("cy", String(toY(states[recvState].marker)));
      tl.fromTo(receiver, { opacity: 0 }, { opacity: 0.95, duration: 0.4 }, recvState - 0.4);
      tl.to(receiver, { opacity: 0, duration: 0.4 }, recvState + 0.6);
      gsap.to(receiver, { rotation: 360, transformOrigin: "center", duration: 9, ease: "none", repeat: -1, svgOrigin: `${toX(states[recvState].marker)} ${toY(states[recvState].marker)}` });
    }

    // heatmap — fade in on the final (goal) segment.
    // (the review-clips card is toggled reverse-safely in the ScrollTrigger onUpdate)
    if (goalState > 0) {
      const heatmap = stage.querySelector("#vth-heatmap");
      tl.fromTo(heatmap, { opacity: 0 }, { opacity: 0.6, duration: 1 }, goalState - 1);
    }

    // keep label + pin aligned on resize
    const onResize = () => { applyTracker(); ScrollTrigger.refresh(); };
    window.addEventListener("resize", onResize, { passive: true });
    requestAnimationFrame(() => ScrollTrigger.refresh());
  }
</script>
