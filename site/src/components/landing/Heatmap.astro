---
/**
 * Heatmap — a clean, on-brand SVG/CSS pitch heatmap (replaces the ugly raw PNGs).
 * `team` shifts the blob distribution. Purely presentational.
 */
interface Props { team?: "team1" | "team2"; label?: string; class?: string; }
const { team = "team1", label, class: cls = "" } = Astro.props;

// blobs: [x%, y%, radius, intensity 0..1]
const t1: [number, number, number, number][] = [
  [30, 50, 46, 1], [22, 34, 34, 0.7], [24, 68, 34, 0.72], [44, 48, 40, 0.85],
  [40, 30, 26, 0.5], [40, 70, 26, 0.5], [58, 52, 30, 0.55], [14, 50, 26, 0.5],
];
const t2: [number, number, number, number][] = [
  [70, 50, 46, 1], [78, 36, 34, 0.72], [76, 66, 34, 0.7], [56, 50, 40, 0.85],
  [60, 30, 26, 0.5], [60, 70, 26, 0.5], [42, 48, 30, 0.55], [86, 50, 26, 0.5],
];
const blobs = team === "team2" ? t2 : t1;
// intensity → heat color (cool green → amber → warm red), muted
const heat = (i: number) =>
  i > 0.85 ? ["#e8563a", "#c9713a"] : i > 0.65 ? ["#d98a3e", "#b08c3f"] : i > 0.5 ? ["#9cb45a", "#77a453"] : ["#6fa657", "#568f49"];
---
<div class={`kfheat ${cls}`}>
  <div class="kfheat-turf"></div>
  {blobs.map(([x, y, r, i]) => {
    const [c1, c2] = heat(i);
    return <span class="kfheat-blob" style={`left:${x}%;top:${y}%;width:${r * 2}%;padding-top:${r * 2}%;background:radial-gradient(circle,${c1} 0%,${c2} 40%,transparent 72%);opacity:${0.3 + i * 0.32}`}></span>;
  })}
  <svg class="kfheat-lines" viewBox="0 0 300 190" preserveAspectRatio="none" aria-hidden="true">
    <g fill="none" stroke="rgba(255,255,255,.5)" stroke-width="1.4">
      <rect x="6" y="6" width="288" height="178" rx="2"/>
      <line x1="150" y1="6" x2="150" y2="184"/>
      <circle cx="150" cy="95" r="26"/>
      <rect x="6" y="52" width="42" height="86"/>
      <rect x="252" y="52" width="42" height="86"/>
      <rect x="6" y="74" width="16" height="42"/>
      <rect x="278" y="74" width="16" height="42"/>
    </g>
    <circle cx="150" cy="95" r="2.4" fill="rgba(255,255,255,.7)"/>
  </svg>
  {label && <span class="kfheat-tag">{label}</span>}
</div>

<style>
  .kfheat { position: relative; width: 100%; aspect-ratio: 300 / 190; border-radius: var(--r-sm);
    overflow: hidden; background: #162913; isolation: isolate; }
  .kfheat-turf { position: absolute; inset: 0;
    background:
      repeating-linear-gradient(90deg, rgba(255,255,255,.028) 0 8.33%, rgba(0,0,0,.03) 8.33% 16.66%),
      linear-gradient(160deg, #1d3a17, #14260f); }
  .kfheat-blob { position: absolute; transform: translate(-50%, -50%); border-radius: 50%;
    filter: blur(9px); pointer-events: none; }
  .kfheat-lines { position: absolute; inset: 0; width: 100%; height: 100%; }
  .kfheat-tag { position: absolute; left: 10px; bottom: 9px; font-size: 11px; font-weight: 600;
    letter-spacing: .04em; color: #fff; background: rgba(18,26,14,.6); border: 1px solid rgba(255,255,255,.18);
    padding: 4px 9px; border-radius: 7px; backdrop-filter: blur(4px); }
</style>
