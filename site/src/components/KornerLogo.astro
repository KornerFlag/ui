---
const { size = 44, rounded = 16, shadow = true } = Astro.props;
---

<svg
  class:list={["korner-logo", shadow && "has-shadow"]}
  width={size}
  height={size}
  viewBox="0 0 128 128"
  role="img"
  aria-label="Korner Flags logo"
  style={`--logo-rounded:${rounded}px;`}
>
  <defs>
    <linearGradient id="kornerLogoGradient" x1="8%" y1="8%" x2="88%" y2="92%">
      <stop offset="0%" stop-color="#f7f5d2" />
      <stop offset="18%" stop-color="#c9f79b" />
      <stop offset="46%" stop-color="#74d4d6" />
      <stop offset="76%" stop-color="#4d7ed6" />
      <stop offset="100%" stop-color="#4d49d6" />
    </linearGradient>
    <linearGradient id="kornerLogoGlow" x1="18%" y1="0%" x2="78%" y2="88%">
      <stop offset="0%" stop-color="rgba(255,255,255,0.95)" />
      <stop offset="100%" stop-color="rgba(255,255,255,0.08)" />
    </linearGradient>
  </defs>

  <rect x="6" y="6" width="116" height="116" rx="22" fill="url(#kornerLogoGradient)" />
  <path
    d="M24 92 58 77l2 11-21 9 26 14-9 6-34-18c-2-1-3-3-3-4 0-1 1-2 2-3l3-1Z"
    fill="#fff"
    opacity="0.96"
  />
  <rect
    x="56"
    y="30"
    width="12"
    height="67"
    rx="6"
    transform="rotate(-16 62 63.5)"
    fill="#fff"
  />
  <path
    d="M66 41c16-3 28-2 38 1 9 3 16 4 22 3-7 8-14 15-24 19-8 4-16 7-24 12l-18-36c2 0 4 0 6 1Z"
    fill="#fff"
  />
  <path
    d="M12 106c18-5 42-17 73-39 17-12 29-24 37-34"
    fill="none"
    stroke="url(#kornerLogoGlow)"
    stroke-width="2.2"
    stroke-linecap="round"
    opacity="0.62"
  />
</svg>

<style>
  .korner-logo {
    display: block;
    border-radius: var(--logo-rounded);
    overflow: hidden;
    flex: none;
  }

  .korner-logo.has-shadow {
    filter: drop-shadow(0 10px 20px rgba(13, 34, 62, 0.24));
  }
</style>
