---
import { withBase } from "../lib/site";

const { src, poster = "", title = "Match video" } = Astro.props;
const resolvedSrc = withBase(src);
const resolvedPoster = withBase(poster);
---

<div class="video-shell">
  <video controls playsinline preload="metadata" poster={resolvedPoster}>
    <source src={resolvedSrc} />
    Your browser does not support embedded video playback.
  </video>
</div>

<style>
  .video-shell {
    overflow: hidden;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: linear-gradient(180deg, rgba(11, 22, 38, 0.54), rgba(11, 22, 38, 0.78));
    box-shadow: 0 28px 54px rgba(0, 0, 0, 0.24);
  }

  video {
    width: 100%;
    display: block;
    background: #08111c;
  }
</style>
